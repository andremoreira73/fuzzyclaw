# Database
DB_PASSWORD=
POSTGRES_DB=
POSTGRES_USER=

# Django
DJANGO_SECRET_KEY=
DJANGO_SETTINGS_MODULE=

# Docker socket GID — containers need this to launch agent containers.
# Find yours with: stat -c '%g' /var/run/docker.sock
# Common values: 983 (Arch), 999 (Ubuntu/Debian), 974 (Fedora).
# macOS Docker Desktop handles this automatically — leave the default.
# Required — run: stat -c '%g' /var/run/docker.sock
DOCKER_GID=

# LLM API Keys
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# --- Optional: Web scraping (only needed for web_search / web_scrape tools) ---
SCRAPINGBEE_API_KEY=
SCRAPINGBEE_ENDPOINT="https://app.scrapingbee.com/api/v1/"

# --- Optional: LangSmith tracing ---
LANGCHAIN_API_KEY=
LANGSMITH_ENDPOINT="https://eu.api.smith.langchain.com"
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=

# --- Optional: Volume mount security ---
# if FUZZYCLAW_VOLUME_ALLOWLIST is empty, it can mount anything except blocklist
# FUZZYCLAW_VOLUME_ALLOWLIST=
# if FUZZYCLAW_VOLUME_BLOCKLIST is empty, then '/', '/etc', '/var/run/docker.sock', '/root', '/proc', '/sys', '/dev' are excluded automatically
# FUZZYCLAW_VOLUME_BLOCKLIST=/,/etc,/root,/var/run/docker.sock