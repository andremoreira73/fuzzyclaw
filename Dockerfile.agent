# python:3.12-slim — pinned 2026-03-30
FROM python@sha256:3d5ed973e45820f5ba5e46bd065bd88b3a504ff0724d85980dcd05eab361fcf4

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

# Python dependencies — minimal agent set, no Django
# psycopg[binary] ships pre-built wheels, no gcc needed
COPY requirements-agent.txt .
RUN pip install --no-cache-dir -r requirements-agent.txt

# Container entrypoint + tool implementations
COPY agent_runner.py .
COPY agent_tools/ ./agent_tools/

# Data directory — user/run volumes mount here at /app/data
RUN mkdir -p /app/data

# Non-root user
RUN groupadd -g 1000 appuser && \
    useradd -u 1000 -g 1000 -m appuser && \
    chown -R appuser:appuser /app

USER appuser

ENTRYPOINT ["python", "agent_runner.py"]
